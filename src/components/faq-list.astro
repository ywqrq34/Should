---
const { items = [], compact = false } = Astro.props;
---
<div class={`faq-list ${compact ? 'faq-list--compact' : ''}`}>
  {items.map((item, index) => (
    <details class="faq-list__item" open={index === 0 && !compact}>
      <summary>
        <span class="faq-list__number">{String(index + 1).padStart(2, '0')}</span>
        <span class="faq-list__question">{item.question}</span>
      </summary>
      <div class="faq-list__body">
        <p>{item.answer}</p>
      </div>
    </details>
  ))}
</div>
