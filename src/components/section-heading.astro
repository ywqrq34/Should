---
const { eyebrow, title, description, align = 'center', backdrop, id } = Astro.props;
---
<div class={`section-heading section-heading--${align}`}>
  {eyebrow && <p class="section-heading__eyebrow">{eyebrow}</p>}
  <div class="section-heading__title-wrap">
    {backdrop && <span class="section-heading__backdrop" aria-hidden="true">{backdrop}</span>}
    <h2 class="section-heading__title" id={id} set:html={title}></h2>
  </div>
  {description && <p class="section-heading__description">{description}</p>}
</div>
