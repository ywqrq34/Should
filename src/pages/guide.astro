---
import BaseLayout from '../layouts/base-layout.astro';
import SectionHeading from '../components/section-heading.astro';
import VisualIcon from '../components/visual-icon.astro';
import CtaBanner from '../components/cta-banner.astro';
import { siteConfig, processSteps } from '../data/site-data.js';
---
<BaseLayout pageClass="guide-page" canonical="/guide" title={`이용방법 | ${siteConfig.brandName}`} description="상담 신청, 한도 확인, 진행 안내, 입금 확인까지 베가티켓 이용 절차를 안내합니다.">
  <section class="sub-hero guide-hero">
    <div class="site-container sub-hero__inner">
      <div>
        <p class="sub-hero__eyebrow">GUIDE</p>
        <h1>이용방법</h1>
        <p>카카오톡 상담 신청부터 한도 및 지급률 확인, 진행 안내까지 간단한 절차로 진행.</p>
      </div>
      <VisualIcon type="headset" label="이용방법" />
    </div>
  </section>

  <section class="guide-process-section" aria-labelledby="guide-process-title">
    <div class="site-container">
      <SectionHeading eyebrow="PROCESS" title="진행 절차" description="진행 전 필요한 내용을 먼저 안내하고, 고객 상황에 맞춰 가능 여부를 확인합니다." />
      <div class="guide-process-list">
        {processSteps.map((step) => (
          <article class="guide-process-card">
            <span>{step.step}</span>
            <h2>{step.title}</h2>
            <p>{step.text}</p>
            <strong>{step.tag}</strong>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="guide-note-section" aria-labelledby="guide-note-title">
    <div class="site-container guide-note-section__panel">
      <div>
        <p class="section-heading__eyebrow">NOTICE</p>
        <h2 id="guide-note-title">이용 전 확인해주세요</h2>
        <p>실제 지급률과 진행 가능 여부는 고객님의 한도, 결제 조건, 상황에 따라 달라질 수 있습니다.</p>
      </div>
      <ul class="guide-note-list">
        <li>본인 명의 휴대폰 또는 카드 기준으로 상담합니다.</li>
        <li>상담 후 지급률과 예상 입금액을 안내합니다.</li>
        <li>은행 점검 시간에는 입금 처리가 지연될 수 있습니다.</li>
        <li>타인 명의 이용이나 불법 목적의 진행은 불가합니다.</li>
      </ul>
    </div>
  </section>

  <CtaBanner title="지금 바로 상담 절차를 확인하세요" description="복잡한 설명 없이 필요한 내용만 빠르게 안내해 드립니다." />
</BaseLayout>
